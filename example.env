# Projeto
COMPOSE_PROJECT_NAME=devcore_php
DOCKER_NETWORK_NAME=devcore_php_net
TZ=America/Sao_Paulo

# App/PHP
APP_CONTAINER_NAME=app
APP_DOCKERFILE=docker/app/Dockerfile.php.8.4
APP_UID=1000
APP_GID=1000
APP_NODE_JS=true
APP_SQL_SERVER=false

# Portas App
APP_PORT_HTTP=8080
APP_PORT_LARAVEL=8000
APP_PORT_FPM=9000

# MySQL
MYSQL_CONTAINER_NAME=mysql_db
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=app
DB_DATA_DIR=./dbdata

# phpMyAdmin
PHPMYADMIN_CONTAINER_NAME=phpmyadmin
PHPMYADMIN_PORT=8081
PHPMYADMIN_UPLOAD_LIMIT=128M
PMA_HOST=mysql_db
PMA_PORT=3306
PMA_ARBITRARY=0